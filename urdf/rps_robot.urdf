<?xml version="1.0"?>
<robot name="rps_robot">

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="1 1 0.5"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="1 1 0.5"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0"
               iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- FOREARM LINK -->
  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 1"/>
      <geometry>
        <cylinder radius="0.2" length="2"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 1"/>
      <geometry>
        <cylinder radius="0.2" length="2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- HAND LINK -->
  <link name="hand_link">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="1 0.2 0.2"/>
      </geometry>
      <material name="skin">
        <color rgba="0.9 0.75 0.6 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="1 0.2 0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- FINGER LINKS -->
  <!-- finger_1 -->
  <link name="finger_1_link_1"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_1_link_2"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_1_link_3"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>

  <!-- finger_2 -->
  <link name="finger_2_link_1"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_2_link_2"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_2_link_3"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>

  <!-- finger_3 -->
  <link name="finger_3_link_1"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_3_link_2"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_3_link_3"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>

  <!-- finger_4 -->
  <link name="finger_4_link_1"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_4_link_2"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_4_link_3"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>

  <!-- finger_5 -->
  <link name="finger_5_link_1"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.08" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_5_link_2"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.07" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>
  <link name="finger_5_link_3"><visual><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry><material name="skin"/></visual><collision><origin xyz="0 0 0.15"/><geometry><cylinder radius="0.06" length="0.3"/></geometry></collision><inertial><mass value="0.05"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial></link>

  <!-- JOINT 1: base to forearm -->
  <joint name="base_to_forearm" type="revolute">
    <parent link="base_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- JOINT 2: forearm to hand -->
  <joint name="forearm_to_hand" type="revolute">
    <parent link="forearm_link"/>
    <child link="hand_link"/>
    <origin xyz="0 0 2"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <!-- FINGER JOINTS -->
  <!-- fingers spaced evenly along hand (x: -0.4 to 0.4, step 0.2) -->

  <!-- finger_1: x = -0.4 -->
  <joint name="finger_1_joint_1" type="revolute"><parent link="hand_link"/><child link="finger_1_link_1"/><origin xyz="-0.4 0 0.1"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_1_joint_2" type="revolute"><parent link="finger_1_link_1"/><child link="finger_1_link_2"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_1_joint_3" type="revolute"><parent link="finger_1_link_2"/><child link="finger_1_link_3"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>

  <!-- finger_2: x = -0.2 -->
  <joint name="finger_2_joint_1" type="revolute"><parent link="hand_link"/><child link="finger_2_link_1"/><origin xyz="-0.2 0 0.1"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_2_joint_2" type="revolute"><parent link="finger_2_link_1"/><child link="finger_2_link_2"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_2_joint_3" type="revolute"><parent link="finger_2_link_2"/><child link="finger_2_link_3"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>

  <!-- finger_3: x = 0.0 -->
  <joint name="finger_3_joint_1" type="revolute"><parent link="hand_link"/><child link="finger_3_link_1"/><origin xyz="0.0 0 0.1"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_3_joint_2" type="revolute"><parent link="finger_3_link_1"/><child link="finger_3_link_2"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_3_joint_3" type="revolute"><parent link="finger_3_link_2"/><child link="finger_3_link_3"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>

  <!-- finger_4: x = 0.2 -->
  <joint name="finger_4_joint_1" type="revolute"><parent link="hand_link"/><child link="finger_4_link_1"/><origin xyz="0.2 0 0.1"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_4_joint_2" type="revolute"><parent link="finger_4_link_1"/><child link="finger_4_link_2"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_4_joint_3" type="revolute"><parent link="finger_4_link_2"/><child link="finger_4_link_3"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>

  <!-- finger_5: x = 0.4 -->
  <joint name="finger_5_joint_1" type="revolute"><parent link="hand_link"/><child link="finger_5_link_1"/><origin xyz="0.4 0 0.1"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_5_joint_2" type="revolute"><parent link="finger_5_link_1"/><child link="finger_5_link_2"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>
  <joint name="finger_5_joint_3" type="revolute"><parent link="finger_5_link_2"/><child link="finger_5_link_3"/><origin xyz="0 0 0.3"/><axis xyz="1 0 0"/><limit lower="-1.57" upper="0" effort="5" velocity="1.0"/></joint>

</robot>